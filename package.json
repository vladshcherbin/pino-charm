{
  "name": "pino-charm",
  "description": "Minimal pino formatter",
  "version": "0.5.1",
  "author": "Vlad Shcherbin <vlad.shcherbin@gmail.com>",
  "repository": "vladshcherbin/pino-charm",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "prepublishOnly": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "test": "node --env-file=.env.test --test",
    "test:coverage": "node --env-file=.env.test --test --experimental-test-coverage",
    "typecheck": "tsc"
  },
  "dependencies": {
    "clean-stack": "^6.0.0",
    "extract-stack": "^3.0.0",
    "is-plain-obj": "^4.1.0",
    "pino-abstract-transport": "^3.0.0",
    "redent": "^4.0.0",
    "sonic-boom": "^5.0.0"
  },
  "peerDependencies": {
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@shcherbin/eslint-config-node": "^0.6.0",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "pino": "^10.3.1",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist",
    "readme.md"
  ],
  "keywords": [
    "pino",
    "color",
    "format",
    "pretty",
    "minimal",
    "transport",
    "colada"
  ],
  "engines": {
    "node": ">= 22"
  },
  "sideEffects": false,
  "type": "module",
  "license": "MIT"
}
